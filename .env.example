# Start from your Moodle portal URL, for example:
# https://moodle.example.edu
#
# The REST API URL is usually the same host plus /webservice/rest/server.php:
MOODLE_API_URL=https://moodle.example.edu/webservice/rest/server.php

# Moodle web-service token for your account.
# Common place to check after logging into Moodle:
# https://moodle.example.edu/user/managetoken.php
#
# If that page has no web-service token, your Moodle admin may need to enable
# web services and allow your account to create/use a token.
MOODLE_API_TOKEN=replace_with_your_moodle_webservice_token
